<Window x:Class="PS3TrophiesIsPerfect.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:PS3TrophiesIsPerfect.ViewModels"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.ExtendViewIntoTitleBar="False"
        Title="PS3TrophiesIsPerfect"
        Width="1120" Height="740"
        MinWidth="860" MinHeight="560"
        Background="{StaticResource Surface}"
        TextElement.Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- Flat, subtle toolbar button. -->
        <Style x:Key="ToolButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource Card}" Padding="10,6"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE8E5;" FontSize="16" Margin="0,0,8,0" />
                        <TextBlock Text="Open" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE896;" FontSize="16" Margin="0,0,8,0" />
                        <TextBlock Text="Copy from PSNProfiles" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE74E;" FontSize="16" Margin="0,0,8,0" />
                        <TextBlock Text="Save" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE72C;" FontSize="16" Margin="0,0,8,0" />
                        <TextBlock Text="Refresh" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <TextBox DockPanel.Dock="Right" Width="240" VerticalAlignment="Center"
                         ui:ControlHelper.PlaceholderText="Filter trophies…" />
            </DockPanel>
        </Border>

        <!-- Hero header -->
        <Border Grid.Row="1" Margin="16,16,16,8" Padding="18" CornerRadius="12"
                Background="{StaticResource Card}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Game icon (placeholder) -->
                <Border Grid.Column="0" Width="64" Height="64" CornerRadius="12" Background="#10FFFFFF">
                    <ui:FontIcon Glyph="&#xE735;" FontSize="30" Foreground="{StaticResource Accent}" />
                </Border>

                <StackPanel Grid.Column="1" Margin="18,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding GameTitle}" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding GameSubtitle}" Margin="0,4,0,0"
                               Foreground="{StaticResource TextMuted}" FontSize="13" />
                </StackPanel>

                <!-- Completion ring -->
                <Grid Grid.Column="2" Width="66" Height="66">
                    <Ellipse Stroke="{StaticResource CardBorder}" StrokeThickness="5" />
                    <Ellipse Stroke="{StaticResource Accent}" StrokeThickness="5" StrokeDashCap="Round" />
                    <TextBlock Text="{Binding CompletionText}" HorizontalAlignment="Center"
                               VerticalAlignment="Center" FontWeight="SemiBold" FontSize="15" />
                </Grid>
            </Grid>
        </Border>

        <!-- Trophy list -->
        <Border Grid.Row="2" Margin="16,8,16,16" CornerRadius="12"
                Background="{StaticResource Card}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Trophies}" AutoGenerateColumns="False" IsReadOnly="True"
                      Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                      GridLinesVisibility="None" HeadersVisibility="Column" CanUserResizeRows="False"
                      SelectionMode="Single" RowHeight="52" Margin="6">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Trophy" Width="*" MinWidth="260">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
                                    <Image Source="{Binding TypeIcon}" Width="34" Height="34" Margin="0,0,12,0"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Detail}" FontSize="12"
                                                   Foreground="{StaticResource TextMuted}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Type" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="9" Padding="10,2" HorizontalAlignment="Center"
                                        VerticalAlignment="Center" Background="{Binding TypeBrush}">
                                    <TextBlock Text="{Binding Type}" FontWeight="Bold" Foreground="#0D0D0D" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Got" Binding="{Binding GotText}" Width="70" />
                    <DataGridTextColumn Header="Synced" Binding="{Binding SyncedText}" Width="80" />
                    <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="160" />
                    <DataGridTextColumn Header="Elapsed (+gap)" Binding="{Binding Elapsed}" Width="180" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
