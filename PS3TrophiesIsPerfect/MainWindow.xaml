<Window x:Class="PS3TrophiesIsPerfect.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:PS3TrophiesIsPerfect.ViewModels"
        xmlns:controls="clr-namespace:PS3TrophiesIsPerfect.Controls"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="{Binding WindowTitle}"
        Width="1120" Height="740" MinWidth="860" MinHeight="560"
        AllowDrop="True" DragOver="Window_DragOver" Drop="Window_Drop"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="{StaticResource Surface}"
        TextElement.Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="O" Command="{Binding OpenCommand}" />
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="B2V" />
        <Style x:Key="ToolButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource Card}" Padding="10,6"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}" Command="{Binding OpenCommand}"
                        ToolTip="Open a trophy folder (Ctrl+O)">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE8E5;" FontSize="16" Margin="0,0,8,0" />
                        <TextBlock Text="Open" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}" Command="{Binding ScrapeCommand}"
                        ToolTip="Scrape unlock times from a PSNProfiles page">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE896;" FontSize="16" Margin="0,0,8,0" />
                        <TextBlock Text="Copy from PSNProfiles" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}" Command="{Binding SaveCommand}"
                        ToolTip="Save changes back to the trophy folder (Ctrl+S)">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE74E;" FontSize="16" Margin="0,0,8,0" />
                        <TextBlock Text="Save" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}" Command="{Binding RefreshCommand}"
                        ToolTip="Reload the trophy list (F5)">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE72C;" FontSize="16" Margin="0,0,8,0" />
                        <TextBlock Text="Refresh" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}" Command="{Binding ClearCommand}"
                        ToolTip="Lock every trophy (clear all unlock times)">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE74D;" FontSize="16" Margin="0,0,8,0" />
                        <TextBlock Text="Clear" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <TextBox x:Name="FilterBox" DockPanel.Dock="Right" Width="220" VerticalAlignment="Center"
                         Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                         ui:ControlHelper.PlaceholderText="Filter trophies… (Ctrl+F)" />
                <ComboBox DockPanel.Dock="Right" Width="150" VerticalAlignment="Center" Margin="0,0,8,0"
                          ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                          ToolTip="PSN profile to sign trophies with when saving" />
            </DockPanel>
        </Border>

        <!-- Hero header -->
        <Border Grid.Row="1" Margin="16,16,16,8" Padding="18" CornerRadius="12"
                Background="{StaticResource Card}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="100" Height="56" CornerRadius="8" Background="#10FFFFFF"
                        ClipToBounds="True">
                    <Grid>
                        <ui:FontIcon Glyph="&#xE735;" FontSize="28" Foreground="{StaticResource Accent}" />
                        <Image Source="{Binding GameIcon}" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Margin="18,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding GameTitle}" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding GameSubtitle}" Margin="0,4,0,0"
                               Foreground="{StaticResource TextMuted}" FontSize="13" />
                </StackPanel>

                <controls:CompletionRing Grid.Column="2" Width="66" Height="66" Percent="{Binding CompletionPercent}" />
            </Grid>
        </Border>

        <!-- Trophy list (+ empty / busy overlays) -->
        <Grid Grid.Row="2" Margin="16,8,16,16">
            <Border CornerRadius="12" Background="{StaticResource Card}"
                    BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                <DataGrid x:Name="Grid" ItemsSource="{Binding Trophies}" AutoGenerateColumns="False" IsReadOnly="True"
                          Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                          GridLinesVisibility="None" HeadersVisibility="Column" CanUserResizeRows="False"
                          SelectionMode="Single" RowHeight="52" Margin="6"
                          MouseDoubleClick="Grid_DoubleClick" PreviewMouseRightButtonDown="Grid_RightDown">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Got}" Value="False">
                                    <Setter Property="Opacity" Value="0.4" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Synced}" Value="True">
                                    <Setter Property="Background" Value="#3A2026" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Set / change time…" Click="Ctx_Edit" />
                            <MenuItem Header="Lock (remove unlock)" Click="Ctx_Lock" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Trophy" Width="*" MinWidth="260" SortMemberPath="Name">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
                                        <Image Source="{Binding Display}" Width="34" Height="34" Margin="0,0,12,0"
                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Detail}" FontSize="12"
                                                       Foreground="{StaticResource TextMuted}" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Type" Width="64" SortMemberPath="Type">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding TypeBadge}" Width="26" Height="26"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Got" Binding="{Binding GotText}" Width="70" />
                        <DataGridTextColumn Header="Synced" Binding="{Binding SyncedText}" Width="80" />
                        <DataGridTextColumn Header="Time" Binding="{Binding TimeText}" Width="170" />
                        <DataGridTextColumn Header="Elapsed (+gap)" Binding="{Binding Elapsed}" Width="180" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Empty state -->
            <Border CornerRadius="12" Background="{StaticResource Card}"
                    Visibility="{Binding EmptyHintVisible, Converter={StaticResource B2V}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ui:FontIcon Glyph="&#xE8E5;" FontSize="40" Foreground="{StaticResource TextMuted}" />
                    <TextBlock Text="Open a trophy folder, or drag one here" Margin="0,14,0,0"
                               Foreground="{StaticResource TextMuted}" FontSize="14" />
                </StackPanel>
            </Border>

            <!-- Busy overlay -->
            <Border Background="#C00D0D0D" CornerRadius="12"
                    Visibility="{Binding IsBusy, Converter={StaticResource B2V}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ui:ProgressRing IsActive="{Binding IsBusy}" Width="48" Height="48" />
                    <TextBlock Text="{Binding BusyText}" Margin="0,16,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
