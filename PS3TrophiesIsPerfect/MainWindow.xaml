<Window
  x:Class="PS3TrophiesIsPerfect.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.modernwpf.com/2019"
  xmlns:vm="clr-namespace:PS3TrophiesIsPerfect.ViewModels"
  xmlns:controls="clr-namespace:PS3TrophiesIsPerfect.Controls"
  xmlns:views="clr-namespace:PS3TrophiesIsPerfect.Views"
  xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
  Title="{Binding WindowTitle}"
  Icon="Assets/logo.png"
  WindowStyle="None"
  Width="1180"
  Height="760"
  MinWidth="900"
  MinHeight="560"
  AllowDrop="True"
  DragOver="Window_DragOver"
  Drop="Window_Drop"
  PreviewKeyDown="Window_PreviewKeyDown"
  Background="{StaticResource Surface}"
  TextElement.Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
  FontFamily="Segoe UI"
>
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome
      CaptionHeight="32"
      ResizeBorderThickness="6"
      CornerRadius="0"
      GlassFrameThickness="0"
      UseAeroCaptionButtons="False"
    />
  </shell:WindowChrome.WindowChrome>
  <Window.DataContext>
    <vm:MainViewModel />
  </Window.DataContext>
  <Window.InputBindings>
    <KeyBinding Modifiers="Control" Key="O" Command="{Binding OpenCommand}" />
    <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveCommand}" />
    <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
  </Window.InputBindings>
  <Grid x:Name="RootGrid">
    <Grid.RowDefinitions>
      <RowDefinition Height="32" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <!-- Custom title bar (with a blue light-streak accent line, echoing the banner) -->
    <Border Grid.Row="0" Background="{StaticResource HeaderBg}" BorderThickness="0,0,0,2">
      <Border.BorderBrush>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
          <GradientStop Color="#0188F5" Offset="0" />
          <GradientStop Color="#4FAAFF" Offset="0.22" />
          <GradientStop Color="#015FB0" Offset="0.55" />
          <GradientStop Color="#0008090C" Offset="1" />
        </LinearGradientBrush>
      </Border.BorderBrush>
      <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
          <Image
            Source="Assets/logo.png"
            Width="22"
            Height="22"
            Margin="0,0,8,0"
            Stretch="Uniform"
            RenderOptions.BitmapScalingMode="HighQuality"
          />
          <TextBlock
            Text="{Binding WindowTitle}"
            FontSize="12"
            VerticalAlignment="Center"
            Foreground="{StaticResource Text}"
          />
        </StackPanel>
        <StackPanel
          Orientation="Horizontal"
          HorizontalAlignment="Right"
          shell:WindowChrome.IsHitTestVisibleInChrome="True"
        >
          <Button Style="{StaticResource CaptionButton}" Click="Min_Click" ToolTip="Minimize">
            <ui:FontIcon Glyph="" FontSize="10" />
          </Button>
          <Button
            x:Name="MaxButton"
            Style="{StaticResource CaptionButton}"
            Click="MaxRestore_Click"
            ToolTip="Maximize"
          >
            <ui:FontIcon x:Name="MaxIcon" Glyph="" FontSize="10" />
          </Button>
          <Button Style="{StaticResource CloseButton}" Click="Close_Click" ToolTip="Close">
            <ui:FontIcon Glyph="" FontSize="10" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>
    <!-- Toolbar -->
    <Border
      Grid.Row="1"
      Background="{StaticResource Card}"
      Padding="10,6"
      BorderBrush="{StaticResource CardBorder}"
      BorderThickness="0,0,0,1"
    >
      <DockPanel LastChildFill="False">
        <Button
          DockPanel.Dock="Left"
          Style="{StaticResource ToolButton}"
          Command="{Binding OpenCommand}"
          ToolTip="Open a trophy folder (Ctrl+O)"
        >
          <StackPanel Orientation="Horizontal">
            <ui:FontIcon Glyph="" Style="{StaticResource ToolIcon}" />
            <TextBlock Text="Open" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button
          DockPanel.Dock="Left"
          Style="{StaticResource ToolButton}"
          Command="{Binding ScrapeCommand}"
          ToolTip="Scrape unlock times from a PSNProfiles page"
        >
          <StackPanel Orientation="Horizontal">
            <ui:FontIcon Glyph="" Style="{StaticResource ToolIcon}" />
            <TextBlock Text="Copy from PSNProfiles" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button
          DockPanel.Dock="Left"
          Style="{StaticResource ToolButton}"
          Command="{Binding RelocateCommand}"
          ToolTip="Re-roll the cloned run as night sessions from a new start date (no re-scrape)"
        >
          <StackPanel Orientation="Horizontal">
            <ui:FontIcon Glyph="" Style="{StaticResource ToolIcon}" />
            <TextBlock Text="Relocate" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button
          DockPanel.Dock="Left"
          Style="{StaticResource ToolButton}"
          Command="{Binding SaveCommand}"
          ToolTip="Save changes back to the trophy folder (Ctrl+S)"
        >
          <StackPanel Orientation="Horizontal">
            <ui:FontIcon Glyph="" Style="{StaticResource ToolIcon}" />
            <TextBlock Text="Save" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button
          DockPanel.Dock="Left"
          Style="{StaticResource ToolButton}"
          Command="{Binding RefreshCommand}"
          ToolTip="Reload the trophy list (F5)"
        >
          <StackPanel Orientation="Horizontal">
            <ui:FontIcon Glyph="" Style="{StaticResource ToolIcon}" />
            <TextBlock Text="Refresh" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button
          DockPanel.Dock="Left"
          Style="{StaticResource ToolButton}"
          Command="{Binding ClearCommand}"
          ToolTip="Lock every trophy (clear all unlock times)"
        >
          <StackPanel Orientation="Horizontal">
            <ui:FontIcon Glyph="" Style="{StaticResource ToolIcon}" />
            <TextBlock Text="Clear" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button
          DockPanel.Dock="Left"
          Style="{StaticResource ToolButton}"
          Command="{Binding CheckCommand}"
          ToolTip="Scan the run for legitimacy red flags before you sync"
        >
          <StackPanel Orientation="Horizontal">
            <ui:FontIcon Glyph="" Style="{StaticResource ToolIcon}" />
            <TextBlock Text="Check" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button
          DockPanel.Dock="Left"
          Style="{StaticResource ToolButton}"
          Command="{Binding MyGamesCommand}"
          ToolTip="Fetch your PS3 games + completion from your linked PSNProfiles account"
        >
          <StackPanel Orientation="Horizontal">
            <ui:FontIcon Glyph="" Style="{StaticResource ToolIcon}" />
            <TextBlock Text="My PS3 Games" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <!-- Linked PSN account (avatar + name, persisted); click to set/change. -->
        <Button
          DockPanel.Dock="Right"
          Style="{StaticResource ToolButton}"
          Margin="0,0,8,0"
          Command="{Binding SetMyUserCommand}"
          ToolTip="Your linked PSN account — click to set or change"
        >
          <StackPanel Orientation="Horizontal">
            <Grid
              Width="22"
              Height="22"
              Margin="0,0,8,0"
              Visibility="{Binding HasMyUser, Converter={StaticResource B2V}}"
            >
              <Ellipse Fill="#222222" />
              <Ellipse>
                <Ellipse.Fill>
                  <ImageBrush ImageSource="{Binding MyAvatarUrl}" Stretch="UniformToFill" />
                </Ellipse.Fill>
              </Ellipse>
            </Grid>
            <ui:FontIcon
              Glyph=""
              Style="{StaticResource ToolIcon}"
              Visibility="{Binding NoMyUser, Converter={StaticResource B2V}}"
            />
            <StackPanel VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding AccountChipText}" VerticalAlignment="Center" />
                <Border
                  Visibility="{Binding HasPsnSummary, Converter={StaticResource B2V}}"
                  Background="#16294A"
                  CornerRadius="4"
                  Padding="5,0"
                  Margin="6,0,0,0"
                  VerticalAlignment="Center"
                >
                  <TextBlock
                    Text="{Binding PsnLevelText}"
                    Foreground="{StaticResource Accent}"
                    FontSize="10"
                    FontWeight="SemiBold"
                  />
                </Border>
              </StackPanel>
              <StackPanel
                Orientation="Horizontal"
                Margin="0,2,0,0"
                Visibility="{Binding HasPsnSummary, Converter={StaticResource B2V}}"
              >
                <Image
                  Source="pack://application:,,,/Assets/TrophyTypes/plat.png"
                  Width="12"
                  Height="12"
                />
                <TextBlock
                  Text="{Binding PsnPlat}"
                  FontSize="10"
                  Foreground="{StaticResource TextMuted}"
                  Margin="3,0,8,0"
                  VerticalAlignment="Center"
                />
                <Image
                  Source="pack://application:,,,/Assets/TrophyTypes/gold.png"
                  Width="12"
                  Height="12"
                />
                <TextBlock
                  Text="{Binding PsnGold}"
                  FontSize="10"
                  Foreground="{StaticResource TextMuted}"
                  Margin="3,0,8,0"
                  VerticalAlignment="Center"
                />
                <Image
                  Source="pack://application:,,,/Assets/TrophyTypes/silver.png"
                  Width="12"
                  Height="12"
                />
                <TextBlock
                  Text="{Binding PsnSilver}"
                  FontSize="10"
                  Foreground="{StaticResource TextMuted}"
                  Margin="3,0,8,0"
                  VerticalAlignment="Center"
                />
                <Image
                  Source="pack://application:,,,/Assets/TrophyTypes/bronze.png"
                  Width="12"
                  Height="12"
                />
                <TextBlock
                  Text="{Binding PsnBronze}"
                  FontSize="10"
                  Foreground="{StaticResource TextMuted}"
                  Margin="3,0,0,0"
                  VerticalAlignment="Center"
                />
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Button>
        <TextBox
          x:Name="FilterBox"
          DockPanel.Dock="Right"
          Width="170"
          VerticalAlignment="Center"
          Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
          ui:ControlHelper.PlaceholderText="Filter trophies…"
        />
        <ComboBox
          DockPanel.Dock="Right"
          Width="130"
          VerticalAlignment="Center"
          Margin="0,0,8,0"
          ItemsSource="{Binding Profiles}"
          SelectedItem="{Binding SelectedProfile}"
          ToolTip="PSN profile to sign trophies with when saving"
        />
      </DockPanel>
    </Border>
    <!-- Hero header -->
    <Border
      Grid.Row="2"
      Margin="16,16,16,8"
      Padding="18"
      CornerRadius="12"
      Background="{StaticResource Card}"
      BorderBrush="{StaticResource CardBorder}"
      BorderThickness="1"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Border
          Grid.Column="0"
          Width="100"
          Height="56"
          CornerRadius="8"
          Background="#10FFFFFF"
          ClipToBounds="True"
        >
          <Grid>
            <ui:FontIcon Glyph="" FontSize="28" Foreground="{StaticResource Accent}" />
            <Image
              Source="{Binding GameIcon}"
              Stretch="Uniform"
              RenderOptions.BitmapScalingMode="HighQuality"
            />
          </Grid>
        </Border>
        <StackPanel Grid.Column="1" Margin="18,0" VerticalAlignment="Center">
          <TextBlock Text="{Binding GameTitle}" FontSize="22" FontWeight="SemiBold" />
          <TextBlock
            Text="{Binding GameSubtitle}"
            Margin="0,4,0,0"
            Foreground="{StaticResource TextMuted}"
            FontSize="13"
          />
        </StackPanel>
        <controls:CompletionRing
          Grid.Column="2"
          Width="66"
          Height="66"
          Percent="{Binding CompletionPercent}"
        />
        <Button
          Grid.Column="3"
          Style="{StaticResource ToolButton}"
          Command="{Binding CloseCommand}"
          VerticalAlignment="Top"
          Margin="14,-6,-6,0"
          ToolTip="Close this folder (back to the welcome screen)"
          Visibility="{Binding HasGame, Converter={StaticResource B2V}}"
        >
          <ui:FontIcon Glyph="" FontSize="13" Foreground="{StaticResource TextMuted}" />
        </Button>
      </Grid>
    </Border>
    <!-- Tabs: trophies / comparison / library -->
    <Grid Grid.Row="3" Margin="16,4,16,16">
      <TabControl
        SelectedIndex="{Binding SelectedTab}"
        Background="Transparent"
        BorderThickness="0"
        Padding="0"
      >
        <TabItem Header="Trophies">
          <views:TrophiesView />
        </TabItem>
        <TabItem
          Header="Comparison"
          Visibility="{Binding HasDonor, Converter={StaticResource B2V}}"
        >
          <views:ComparisonView />
        </TabItem>
        <TabItem
          Header="My PS3 Games"
          Visibility="{Binding HasMyGames, Converter={StaticResource B2V}}"
        >
          <views:LibraryView />
        </TabItem>
      </TabControl>
      <!-- Busy overlay over everything -->
      <Border
        Background="#C00D0D0D"
        CornerRadius="12"
        Visibility="{Binding IsBusy, Converter={StaticResource B2V}}"
      >
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
          <ui:ProgressRing IsActive="{Binding IsBusy}" Width="48" Height="48" />
          <TextBlock Text="{Binding BusyText}" Margin="0,16,0,0" HorizontalAlignment="Center" />
        </StackPanel>
      </Border>
      <!-- Toast: brief, non-blocking confirmation -->
      <Border
        VerticalAlignment="Bottom"
        HorizontalAlignment="Center"
        Margin="0,0,0,28"
        Background="#F0202020"
        BorderBrush="{StaticResource CardBorder}"
        BorderThickness="1"
        CornerRadius="8"
        Padding="18,11"
        IsHitTestVisible="False"
      >
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Opacity" Value="0" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding ToastVisible}" Value="True">
                <DataTrigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation
                        Storyboard.TargetProperty="Opacity"
                        To="1"
                        Duration="0:0:0.2"
                      />
                    </Storyboard>
                  </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation
                        Storyboard.TargetProperty="Opacity"
                        To="0"
                        Duration="0:0:0.45"
                      />
                    </Storyboard>
                  </BeginStoryboard>
                </DataTrigger.ExitActions>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <StackPanel Orientation="Horizontal">
          <ui:FontIcon Glyph="" FontSize="14" Foreground="{StaticResource Accent}" />
          <TextBlock
            Text="{Binding ToastText}"
            Margin="10,0,0,0"
            Foreground="{StaticResource Text}"
            VerticalAlignment="Center"
          />
        </StackPanel>
      </Border>
    </Grid>
    <!-- Status bar -->
    <Border
      Grid.Row="4"
      Background="{StaticResource HeaderBg}"
      BorderBrush="{StaticResource CardBorder}"
      BorderThickness="0,1,0,0"
      Padding="14,5"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock
          Grid.Column="0"
          Text="{Binding StatusFolder}"
          Foreground="{StaticResource TextMuted}"
          FontSize="11"
          VerticalAlignment="Center"
          TextTrimming="CharacterEllipsis"
          Margin="0,0,12,0"
        />
        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <TextBlock
            Text="{Binding StatusSave}"
            Foreground="{StaticResource TextMuted}"
            FontSize="11"
            VerticalAlignment="Center"
          />
          <TextBlock
            Text="   ·   "
            Foreground="{StaticResource CardBorder}"
            FontSize="11"
            VerticalAlignment="Center"
          />
          <TextBlock
            Text="{Binding StatusAccount}"
            Foreground="{StaticResource TextMuted}"
            FontSize="11"
            VerticalAlignment="Center"
          />
          <TextBlock
            Text="   ·   "
            Foreground="{StaticResource CardBorder}"
            FontSize="11"
            VerticalAlignment="Center"
          />
          <TextBlock
            Text="{Binding ScrapeStatus}"
            Foreground="{StaticResource TextMuted}"
            FontSize="11"
            VerticalAlignment="Center"
          />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
