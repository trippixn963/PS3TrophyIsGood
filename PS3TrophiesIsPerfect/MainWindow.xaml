<Window x:Class="PS3TrophiesIsPerfect.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:PS3TrophiesIsPerfect.ViewModels"
        xmlns:controls="clr-namespace:PS3TrophiesIsPerfect.Controls"
        xmlns:views="clr-namespace:PS3TrophiesIsPerfect.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{Binding WindowTitle}"
        WindowStyle="None"
        Width="1180" Height="760" MinWidth="900" MinHeight="560"
        AllowDrop="True" DragOver="Window_DragOver" Drop="Window_Drop"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="{StaticResource Surface}"
        TextElement.Foreground="{DynamicResource SystemControlPageTextBaseHighBrush}"
        FontFamily="Segoe UI">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="O" Command="{Binding OpenCommand}" />
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    </Window.InputBindings>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBg}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <ui:FontIcon Glyph="&#xE735;" FontSize="14" Foreground="{StaticResource Accent}" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding WindowTitle}" FontSize="12" VerticalAlignment="Center"
                               Foreground="{StaticResource Text}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource CaptionButton}" Click="Min_Click" ToolTip="Minimize">
                        <ui:FontIcon Glyph="&#xE921;" FontSize="10" />
                    </Button>
                    <Button x:Name="MaxButton" Style="{StaticResource CaptionButton}" Click="MaxRestore_Click" ToolTip="Maximize">
                        <ui:FontIcon x:Name="MaxIcon" Glyph="&#xE922;" FontSize="10" />
                    </Button>
                    <Button Style="{StaticResource CloseButton}" Click="Close_Click" ToolTip="Close">
                        <ui:FontIcon Glyph="&#xE8BB;" FontSize="10" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{StaticResource Card}" Padding="10,6"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}" Command="{Binding OpenCommand}"
                        ToolTip="Open a trophy folder (Ctrl+O)">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE8E5;" FontSize="16" Margin="0,0,8,0" />
                        <TextBlock Text="Open" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}" Command="{Binding ScrapeCommand}"
                        ToolTip="Scrape unlock times from a PSNProfiles page">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE896;" FontSize="16" Margin="0,0,8,0" />
                        <TextBlock Text="Copy from PSNProfiles" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}" Command="{Binding SaveCommand}"
                        ToolTip="Save changes back to the trophy folder (Ctrl+S)">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE74E;" FontSize="16" Margin="0,0,8,0" />
                        <TextBlock Text="Save" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}" Command="{Binding RefreshCommand}"
                        ToolTip="Reload the trophy list (F5)">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE72C;" FontSize="16" Margin="0,0,8,0" />
                        <TextBlock Text="Refresh" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}" Command="{Binding ClearCommand}"
                        ToolTip="Lock every trophy (clear all unlock times)">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE74D;" FontSize="16" Margin="0,0,8,0" />
                        <TextBlock Text="Clear" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button DockPanel.Dock="Left" Style="{StaticResource ToolButton}" Command="{Binding MyGamesCommand}"
                        ToolTip="Fetch your PS3 games + completion from your linked PSNProfiles account">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE7FC;" FontSize="16" Margin="0,0,8,0" />
                        <TextBlock Text="My PS3 Games" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Linked PSN account (avatar + name, persisted); click to set/change. -->
                <Button DockPanel.Dock="Right" Style="{StaticResource ToolButton}" Margin="0,0,8,0"
                        Command="{Binding SetMyUserCommand}" ToolTip="Your linked PSN account — click to set or change">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="22" Height="22" Margin="0,0,8,0"
                              Visibility="{Binding HasMyUser, Converter={StaticResource B2V}}">
                            <Ellipse Fill="#222222" />
                            <Ellipse>
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{Binding MyAvatarUrl}" Stretch="UniformToFill" />
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>
                        <ui:FontIcon Glyph="&#xE77B;" FontSize="15" Margin="0,0,6,0"
                                     Visibility="{Binding NoMyUser, Converter={StaticResource B2V}}" />
                        <TextBlock Text="{Binding AccountChipText}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <TextBox x:Name="FilterBox" DockPanel.Dock="Right" Width="220" VerticalAlignment="Center"
                         Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                         ui:ControlHelper.PlaceholderText="Filter trophies… (Ctrl+F)" />
                <ComboBox DockPanel.Dock="Right" Width="150" VerticalAlignment="Center" Margin="0,0,8,0"
                          ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                          ToolTip="PSN profile to sign trophies with when saving" />
            </DockPanel>
        </Border>

        <!-- Hero header -->
        <Border Grid.Row="2" Margin="16,16,16,8" Padding="18" CornerRadius="12"
                Background="{StaticResource Card}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="100" Height="56" CornerRadius="8" Background="#10FFFFFF"
                        ClipToBounds="True">
                    <Grid>
                        <ui:FontIcon Glyph="&#xE735;" FontSize="28" Foreground="{StaticResource Accent}" />
                        <Image Source="{Binding GameIcon}" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Margin="18,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding GameTitle}" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding GameSubtitle}" Margin="0,4,0,0"
                               Foreground="{StaticResource TextMuted}" FontSize="13" />
                </StackPanel>

                <controls:CompletionRing Grid.Column="2" Width="66" Height="66" Percent="{Binding CompletionPercent}" />
            </Grid>
        </Border>

        <!-- Tabs: trophies / comparison / library -->
        <Grid Grid.Row="3" Margin="16,4,16,16">
            <TabControl SelectedIndex="{Binding SelectedTab}" Background="Transparent" BorderThickness="0" Padding="0">
                <TabItem Header="Trophies">
                    <views:TrophiesView />
                </TabItem>
                <TabItem Header="Comparison" Visibility="{Binding HasDonor, Converter={StaticResource B2V}}">
                    <views:ComparisonView />
                </TabItem>
                <TabItem Header="My PS3 Games" Visibility="{Binding HasMyGames, Converter={StaticResource B2V}}">
                    <views:LibraryView />
                </TabItem>
            </TabControl>

            <!-- Busy overlay over everything -->
            <Border Background="#C00D0D0D" CornerRadius="12"
                    Visibility="{Binding IsBusy, Converter={StaticResource B2V}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ui:ProgressRing IsActive="{Binding IsBusy}" Width="48" Height="48" />
                    <TextBlock Text="{Binding BusyText}" Margin="0,16,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
