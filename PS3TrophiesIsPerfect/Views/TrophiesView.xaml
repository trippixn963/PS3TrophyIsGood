<UserControl x:Class="PS3TrophiesIsPerfect.Views.TrophiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019">
    <Grid Margin="0,8,0,0">
        <Border CornerRadius="12" Background="{StaticResource Card}"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
            <DataGrid x:Name="Grid" Style="{StaticResource ListGrid}" ItemsSource="{Binding Trophies}"
                      MouseDoubleClick="Grid_DoubleClick" PreviewMouseRightButtonDown="Grid_RightDown">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="{StaticResource Text}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Got}" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Synced}" Value="True">
                                <Setter Property="Background" Value="#3A2026" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Set / change time…" Click="Ctx_Edit" />
                        <MenuItem Header="Lock (remove unlock)" Click="Ctx_Lock" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Trophy" Width="*" MinWidth="240" SortMemberPath="Name">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
                                    <Image Source="{Binding Display}" Width="34" Height="34" Margin="0,0,12,0"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Detail}" FontSize="12"
                                                   Foreground="{StaticResource TextMuted}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Type" Width="56" SortMemberPath="Type">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding TypeBadge}" Width="26" Height="26"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Got" Binding="{Binding GotText}" Width="60" />
                    <DataGridTextColumn Header="Synced" Binding="{Binding SyncedText}" Width="70" />
                    <DataGridTextColumn Header="Time" Binding="{Binding TimeText}" Width="160" />
                    <DataGridTextColumn Header="Elapsed (+gap)" Binding="{Binding Elapsed}" Width="170" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border CornerRadius="12" Background="{StaticResource Card}"
                Visibility="{Binding EmptyHintVisible, Converter={StaticResource B2V}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:FontIcon Glyph="&#xE8E5;" FontSize="40" Foreground="{StaticResource TextMuted}" />
                <TextBlock Text="Open a trophy folder, or drag one here" Margin="0,14,0,0"
                           Foreground="{StaticResource TextMuted}" FontSize="14" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
