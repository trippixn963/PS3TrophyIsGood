<UserControl x:Class="PS3TrophiesIsPerfect.Views.TrophiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             MouseDoubleClick="Trophy_DoubleClick">
    <Grid Margin="0,8,0,0">
        <Border CornerRadius="12" Background="{StaticResource Card}"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                Visibility="{Binding HasGame, Converter={StaticResource B2V}}">
            <DockPanel>
                <!-- Sort / count bar -->
                <Border DockPanel.Dock="Top" Background="#1C1C1C" CornerRadius="12,12,0,0"
                        Padding="14,8" BorderBrush="{StaticResource CardBorder}" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="{Binding TrophyCountText}" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMuted}" FontSize="12" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="Sort" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{StaticResource TextMuted}" FontSize="12" />
                            <ComboBox Width="150" VerticalAlignment="Center"
                                      ItemsSource="{Binding TrophySorts}" SelectedItem="{Binding TrophySort}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Trophy cards -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <ItemsControl ItemsSource="{Binding Trophies}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" BorderBrush="{StaticResource CardBorder}"
                                        BorderThickness="1" Margin="0,0,0,8" Padding="10" Cursor="Hand"
                                        Opacity="{Binding RowOpacity}"
                                        ToolTip="Double-click to set / change time · right-click for more">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1C1C1C" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Synced}" Value="True">
                                                    <Setter Property="Background" Value="#3A2026" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="Set / change time…" Click="Ctx_Edit" />
                                            <MenuItem Header="Lock (remove unlock)" Click="Ctx_Lock" />
                                        </ContextMenu>
                                    </Border.ContextMenu>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon + type badge -->
                                        <Grid Grid.Column="0">
                                            <Border Width="54" Height="54" CornerRadius="6"
                                                    Background="#10FFFFFF" ClipToBounds="True">
                                                <Image Source="{Binding Display}" Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                            </Border>
                                            <Image Source="{Binding TypeBadge}" Width="20" Height="20"
                                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                   Margin="0,0,-5,-5" />
                                        </Grid>

                                        <StackPanel Grid.Column="1" Margin="20,0,12,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                                            <TextBlock Text="{Binding Detail}" Foreground="{StaticResource TextMuted}"
                                                       FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" MinWidth="160">
                                            <TextBlock Text="{Binding TimeDisplay}" FontSize="12"
                                                       HorizontalAlignment="Right" />
                                            <TextBlock Text="{Binding ElapsedDisplay}" Foreground="{StaticResource TextMuted}"
                                                       FontSize="11" Margin="0,3,0,0" HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Empty state -->
        <Border CornerRadius="12" Background="{StaticResource Card}"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="1"
                Visibility="{Binding EmptyHintVisible, Converter={StaticResource B2V}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:FontIcon Glyph="&#xE8E5;" FontSize="40" Foreground="{StaticResource TextMuted}" />
                <TextBlock Text="Open a trophy folder, or drag one here" Margin="0,14,0,0"
                           Foreground="{StaticResource TextMuted}" FontSize="14" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
