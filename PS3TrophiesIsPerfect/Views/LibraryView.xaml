<UserControl x:Class="PS3TrophiesIsPerfect.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             MouseDoubleClick="Games_DoubleClick">
    <Border Margin="0,8,0,0" CornerRadius="12" Background="{StaticResource Card}"
            BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
            <ItemsControl ItemsSource="{Binding MyGames}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="10" Background="#1C1C1C" BorderBrush="{StaticResource CardBorder}"
                                BorderThickness="1" Margin="0,0,0,8" Padding="10" Cursor="Hand"
                                ToolTip="Open on PSNProfiles">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Banner -->
                                <Border Grid.Column="0" Width="96" Height="54" CornerRadius="6"
                                        Background="#10FFFFFF" ClipToBounds="True">
                                    <Grid>
                                        <ui:FontIcon Glyph="&#xE7FC;" FontSize="22" Foreground="{StaticResource TextMuted}" />
                                        <Image Source="{Binding Icon}" Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Grid>
                                </Border>

                                <!-- Title + count -->
                                <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding CountText}" Foreground="{StaticResource TextMuted}"
                                               FontSize="12" Margin="0,3,0,0" />
                                </StackPanel>

                                <!-- Completion -->
                                <StackPanel Grid.Column="2" Width="200" VerticalAlignment="Center" Margin="8,0,4,0">
                                    <TextBlock Text="{Binding PercentText}" Foreground="{StaticResource Accent}"
                                               FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,5" />
                                    <ProgressBar Value="{Binding Percent}" Maximum="100" Height="6"
                                                 Foreground="{StaticResource Accent}" Background="#2A2A2A" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Border>
</UserControl>
