<UserControl x:Class="PS3TrophiesIsPerfect.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             MouseDoubleClick="Game_DoubleClick">
    <Grid Margin="0,8,0,0">

        <!-- ============ GAMES LIST ============ -->
        <Border Visibility="{Binding NotViewingGame, Converter={StaticResource B2V}}"
                CornerRadius="12" Background="{StaticResource Card}"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                <ItemsControl ItemsSource="{Binding MyGames}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Background="#1C1C1C" BorderBrush="{StaticResource CardBorder}"
                                    BorderThickness="1" Margin="0,0,0,8" Padding="10" Cursor="Hand"
                                    ToolTip="Double-click to view trophies">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="96" Height="54" CornerRadius="6"
                                            Background="#10FFFFFF" ClipToBounds="True">
                                        <Grid>
                                            <ui:FontIcon Glyph="&#xE7FC;" FontSize="22" Foreground="{StaticResource TextMuted}" />
                                            <Image Source="{Binding Icon}" Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding CountText}" Foreground="{StaticResource TextMuted}"
                                                   FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Width="200" VerticalAlignment="Center" Margin="8,0,4,0">
                                        <TextBlock Text="{Binding PercentText}" Foreground="{StaticResource Accent}"
                                                   FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,5" />
                                        <ProgressBar Value="{Binding Percent}" Maximum="100" Height="6"
                                                     Foreground="{StaticResource Accent}" Background="#2A2A2A" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ============ GAME DETAIL (trophy list) ============ -->
        <Border Visibility="{Binding IsViewingGame, Converter={StaticResource B2V}}"
                CornerRadius="12" Background="{StaticResource Card}"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
            <DockPanel>
                <!-- Header: back + banner + title + completion -->
                <Border DockPanel.Dock="Top" Background="#1C1C1C" CornerRadius="12,12,0,0" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Command="{Binding BackToGamesCommand}" Style="{StaticResource ToolButton}"
                                VerticalAlignment="Center" Margin="0,0,12,0" ToolTip="Back to games">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE72B;" FontSize="14" />
                                <TextBlock Text="Back" Margin="6,0,0,0" />
                            </StackPanel>
                        </Button>

                        <Border Grid.Column="1" Width="84" Height="48" CornerRadius="6"
                                Background="#10FFFFFF" ClipToBounds="True" VerticalAlignment="Center">
                            <Image Source="{Binding SelectedGame.Icon}" Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>

                        <StackPanel Grid.Column="2" Margin="14,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedGame.Name}" FontWeight="SemiBold" FontSize="17"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding SelectedGame.CountText}" Foreground="{StaticResource TextMuted}"
                                       FontSize="12" Margin="0,3,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="3" Width="180" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedGame.PercentText}" Foreground="{StaticResource Accent}"
                                       FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,5" />
                            <ProgressBar Value="{Binding SelectedGame.Percent}" Maximum="100" Height="6"
                                         Foreground="{StaticResource Accent}" Background="#2A2A2A" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Trophies -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <ItemsControl ItemsSource="{Binding GameTrophies}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Background="#1C1C1C" BorderBrush="{StaticResource CardBorder}"
                                        BorderThickness="1" Margin="0,0,0,8" Padding="10" Opacity="{Binding EarnedOpacity}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Trophy icon + type badge -->
                                        <Grid Grid.Column="0">
                                            <Border Width="60" Height="60" CornerRadius="6"
                                                    Background="#10FFFFFF" ClipToBounds="True">
                                                <Image Source="{Binding Icon}" Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                            </Border>
                                            <Image Source="{Binding TypeBadge}" Width="22" Height="22"
                                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                   Margin="0,0,-6,-6" />
                                        </Grid>

                                        <StackPanel Grid.Column="1" Margin="20,0,12,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                                            <TextBlock Text="{Binding Detail}" Foreground="{StaticResource TextMuted}"
                                                       FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" MinWidth="150">
                                            <TextBlock Text="{Binding TypeText}" Foreground="{StaticResource TextMuted}"
                                                       FontSize="11" HorizontalAlignment="Right" />
                                            <TextBlock Text="{Binding EarnedText}" FontSize="12" Margin="0,3,0,0"
                                                       HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
