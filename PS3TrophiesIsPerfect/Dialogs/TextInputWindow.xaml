<Window x:Class="PS3TrophiesIsPerfect.Dialogs.TextInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Copy from PSNProfiles"
        Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource Surface}" FontFamily="Segoe UI">
    <StackPanel Margin="20">
        <TextBlock Text="PSNProfiles game-trophy URL" FontWeight="SemiBold" Margin="0,0,0,6" />
        <TextBlock Text="e.g. https://psnprofiles.com/trophies/41027-pragmata/SomeUser"
                   Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap" />
        <TextBox x:Name="UrlBox" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancel" Width="90" IsCancel="True" Margin="0,0,8,0" />
            <Button Content="Scrape" Width="110" IsDefault="True" Click="Ok_Click"
                    Style="{StaticResource AccentButtonStyle}" />
        </StackPanel>
    </StackPanel>
</Window>
