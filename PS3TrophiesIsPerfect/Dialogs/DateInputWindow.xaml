<Window x:Class="PS3TrophiesIsPerfect.Dialogs.DateInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Pick a date"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource Surface}" FontFamily="Segoe UI">
    <StackPanel Margin="20">
        <TextBlock x:Name="Prompt" Text="Date and time" FontWeight="SemiBold" Margin="0,0,0,10" />
        <StackPanel Orientation="Horizontal">
            <DatePicker x:Name="DatePick" Width="160" />
            <TextBox x:Name="HourBox" Width="44" Margin="12,0,0,0" MaxLength="2"
                     ui:ControlHelper.PlaceholderText="HH" />
            <TextBlock Text=":" VerticalAlignment="Center" Margin="3,0" />
            <TextBox x:Name="MinBox" Width="44" MaxLength="2" ui:ControlHelper.PlaceholderText="mm" />
            <TextBlock Text=":" VerticalAlignment="Center" Margin="3,0" />
            <TextBox x:Name="SecBox" Width="44" MaxLength="2" ui:ControlHelper.PlaceholderText="ss" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancel" Width="90" IsCancel="True" Margin="0,0,8,0" />
            <Button Content="OK" Width="110" IsDefault="True" Click="Ok_Click"
                    Style="{StaticResource AccentButtonStyle}" />
        </StackPanel>
    </StackPanel>
</Window>
